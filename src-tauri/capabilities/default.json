{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "enables the default permissions",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"sql:default",
		"fs:default",
		"dialog:default",
		"os:default",
		"core:path:default",
		"core:event:default",
		"core:window:default",
		"fs:allow-applocaldata-read-recursive",
		"fs:allow-applocaldata-write-recursive"
	]
}
